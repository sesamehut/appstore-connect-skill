{
  "name": "appstore-connect-skill",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "contract:fetch": "node scripts/contract/fetch.mjs",
    "contract:generate": "node scripts/contract/generate.mjs",
    "contract:update": "npm run contract:fetch && npm run contract:generate",
    "contract:verify": "node scripts/contract/verify.mjs",
    "contract:drift": "npm run contract:fetch && node scripts/contract/check-drift.mjs",
    "check": "npm run contract:verify && npm run typecheck && npm run lint && npm run format:check && npm run test"
  },
  "overrides": {
    "openapi-typescript": {
      "typescript": "$typescript"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.21",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "fflate": "^0.8.3",
    "globals": "^17.6.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.0",
    "undici": "^7.27.2",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "jose": "^6.2.3",
    "openapi-fetch": "^0.17.0"
  }
}
